# Copie ce fichier en .env et remplis les valeurs

# Django
SECRET_KEY=change-moi-par-une-vraie-cle-secrete
DEBUG=True

# Base de données (laisser vide en dev = SQLite)
DATABASE_URL=

# CORS : URLs du frontend autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# En production sur Render : mettre l'URL PostgreSQL ici
# DATABASE_URL=postgresql://user:password@host/dbname
